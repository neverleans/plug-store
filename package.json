{
  "name": "neverleans-plug-store-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "turbo dev --filter=./apps/demo",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "build:core": "turbo build --filter=@neverleans/plug-store-core",
    "build:themes": "turbo build --filter=@neverleans/plug-store-themes",
    "dev:demo": "turbo dev --filter=./apps/demo",
    "test:coverage": "pnpm --filter=@neverleans/plug-store-core test:coverage",
    "release": "pnpm build && pnpm -r publish --access public --no-git-checks"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "turbo": "^2.5.4",
    "typescript-eslint": "^8.38.0"
  }
}
