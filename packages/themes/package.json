{
  "name": "@neverleans/plug-store-themes",
  "version": "0.1.0",
  "description": "15 built-in industry themes and demo data for @neverleans/plug-store-core",
  "author": "neverleans",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@neverleans/plug-store-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vite-plugin-dts": "^4.3.0"
  }
}
